+	// same sum/reference-count formulation as the CUDA sub-warp reduction below,
+	// without relying on multiple logical sub-warps sharing a Metal SIMD group.
+	const PxU32 bodyId = threadIdx.x + threadIdx.y * blockDim.x +
+		blockIdx.x * blockDim.x * blockDim.y;
+	const PxU32 totalBodyCount = solverDesc->islandContextPool->mBodyCount;
+	if(bodyId < totalBodyCount)
+	{
+		float4* bodyVelocities = sharedDesc->iterativeData.solverBodyVelPool;
+		const PxU32 bodyOffset = solverDesc->islandContextPool->mBodyStartIndex;
+		const PxU32 numSlabs = solverDesc->numSlabs;
+		const PxU32 deltaVOffset = solverDesc->accumulatedBodyDeltaVOffset;
+		const PxU32 averageOutputOffsets =
+			(solverDesc->numBatches + solverDesc->numArticBatches) * PXG_BATCH_SIZE * 4;
+		const PxU32 outputBody = deltaVOffset + bodyId + bodyOffset;
+		const float4 lastLinearVel = bodyVelocities[outputBody];
+		const float4 lastAngularVel = bodyVelocities[outputBody + totalBodyCount + bodyOffset];
+		float4 linDelta = make_float4(0.f);
+		float4 angDelta = make_float4(0.f);
+		bool hasRef = false;
+		for(PxU32 slab = 0; slab < numSlabs; ++slab)
+		{
+			const PxU32 bodyIndex = bodyId * numSlabs + slab;
+			const PxgSolverReferences reference = solverDesc->solverBodyReferences[bodyIndex];
+			if(reference.mRemappedBodyIndex != 0xFFFFFFFF)
+			{
+				const PxU32 velIndex = averageOutputOffsets + ComputeAverageBodyBatchStartIndex(bodyIndex);
