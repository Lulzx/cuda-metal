+__device__ __forceinline__ bool cumetalPointInTriangle(
+	const PxVec3& p, const PxVec3& a, const PxVec3& b, const PxVec3& c)
+{
+	const PxVec3 ab = b - a;
+	const PxVec3 ac = c - a;
+	const PxVec3 ap = p - a;
+	const PxReal d00 = ab.dot(ab);
+	const PxReal d01 = ab.dot(ac);
+	const PxReal d11 = ac.dot(ac);
+	const PxReal d20 = ap.dot(ab);
+	const PxReal d21 = ap.dot(ac);
+	const PxReal denom = d00 * d11 - d01 * d01;
+	if (denom <= 0.0f)
+		return false;
+	const PxReal v = (d11 * d20 - d01 * d21) / denom;
+	const PxReal w = (d00 * d21 - d01 * d20) / denom;
+	const PxReal tolerance = 1e-5f;
+	return v >= -tolerance && w >= -tolerance && v + w <= 1.0f + tolerance;
+}
