+__device__ __forceinline__ PxU32 cumetalSphereTrimeshNarrowphaseCore(
+	const PxgContactManagerInput& npWorkItem,
+	const PxgShape& sphereShape,
+	const PxgShape& trimeshShape,
+	const uint4 curPair,
+	const PxsCachedTransform* PX_RESTRICT transformCache,
+	const PxReal* PX_RESTRICT contactDistance,
+	SphereMeshPair* PX_RESTRICT sphereTrimeshPair,
+	SphereTriNormalAndIndex* PX_RESTRICT sphereTriNI,
+	PxReal* PX_RESTRICT sphereTriMaxDepth,
+	SphereTriIntermediateData* PX_RESTRICT sphereTriInterm,
+	PxU32* PX_RESTRICT orderedSphereTriInterm,
+	PxVec3& outContact,
+	PxReal& outSeparation)
+{
+	const PxU32 cmIdx = curPair.x;
+	const PxU32 triangleIdx = curPair.y;
+	const PxU32 testOffset = curPair.z;
+	const PxsCachedTransform sphereTransform =
+		transformCache[npWorkItem.transformCacheRef0];
+	const PxsCachedTransform trimeshTransform =
+		transformCache[npWorkItem.transformCacheRef1];
+	const SphereMeshPair& pair = sphereTrimeshPair[cmIdx];
+	const PxU32 pairOffset = pair.startIndex + testOffset;
+	const PxU32 paddedOffset = pair.roundedStartIndex + testOffset;
+
+	const PxU8* meshData =
+		reinterpret_cast<const PxU8*>(trimeshShape.hullOrMeshPtr);
+	const float4* vertices;
+	const uint4* triangles;
+	const uint4* adjacencies;
+	const PxU32* faceRemap;
+	readTriangleMesh(meshData, vertices, triangles, adjacencies, faceRemap);
+	(void)adjacencies;
+
+	const MeshScaling meshScale(trimeshShape.scale.scale,
+		trimeshShape.scale.rotation);
+	PxVec3 v0, v1, v2;
+	getShapeSpaceVerts(v0, v1, v2, meshScale, triangleIdx, triangles, vertices);
+	PxVec3 normal = (v1 - v0).cross(v2 - v0).getNormalized();
+	if (meshScale.flipNormal)
+		normal = -normal;
+
+	const PxVec3 sphereCenter =
+		trimeshTransform.transform.transformInv(sphereTransform.transform.p);
+	const PxReal planeDistance = (sphereCenter - v0).dot(normal);
+	const PxVec3 closest = cumetalClosestPointTriangle(sphereCenter, v0, v1, v2);
+	const PxVec3 delta = sphereCenter - closest;
+	const PxReal distanceSquared = delta.magnitudeSquared();
+	const PxReal inflatedRadius =
+		sphereShape.scale.scale.x +
+		contactDistance[npWorkItem.transformCacheRef0] +
+		contactDistance[npWorkItem.transformCacheRef1];
+	const bool hit = planeDistance >= 0.0f &&
+		distanceSquared < inflatedRadius * inflatedRadius;
+	const PxReal separation = hit ? PxSqrt(distanceSquared) : PX_MAX_F32;
+
+	sphereTriMaxDepth[pairOffset] = separation;
+	sphereTriInterm[pairOffset].gpuTriIndex = triangleIdx;
+	orderedSphereTriInterm[paddedOffset] =
+		triangleIdx | (hit ? TriangleSearchFlags::eFACE_CONTACT : 0);
+
+	const PxVec3 worldNormal = trimeshTransform.transform.rotate(-normal);
+	const PxVec3 sphereNormal = sphereTransform.transform.rotateInv(worldNormal);
+	sphereTriNI[pairOffset].normal = sphereNormal;
+	sphereTriNI[pairOffset].index =
+		(PxU32(hit) << SphereTriNormalAndIndex::NbContactsShift) +
+		faceRemap[triangleIdx];
+	outContact = PxVec3(0.0f);
+	outSeparation = separation;
+	return PxU32(hit);
+}
