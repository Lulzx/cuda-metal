+static PxConvexMesh* createConvexPrism()
+{
+	const PxVec3 vertices[] = {
+		PxVec3(-1, -1, -1), PxVec3(1, -1, -1), PxVec3(0, -1, 1),
+		PxVec3(-1, 1, -1), PxVec3(1, 1, -1), PxVec3(0, 1, 1)
+	};
+	PxConvexMeshDesc desc;
+	desc.points.data = vertices;
+	desc.points.count = sizeof(vertices) / sizeof(vertices[0]);
+	desc.points.stride = sizeof(PxVec3);
+	desc.flags = PxConvexFlag::eCOMPUTE_CONVEX;
+	PxCookingParams params(gPhysics->getTolerancesScale());
+	params.buildGPUData = true;
+	return PxCreateConvexMesh(params, desc, gPhysics->getPhysicsInsertionCallback());
+}
