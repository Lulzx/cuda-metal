+					const float4 raTarget = point.raXn_targetVelocity[0];
+					const float4 rbMax = point.rbXn_maxImpulse[0];
+					const PxVec3 ra(raTarget.x, raTarget.y, raTarget.z);
+					const PxVec3 rb(rbMax.x, rbMax.y, rbMax.z);
+					const float response = point.resp0[0] + point.resp1[0];
