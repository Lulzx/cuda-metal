 extern "C" __global__ void computeAverageSolverBodyVelocity(
 	const PxgSolverCoreDesc* const PX_RESTRICT solverDesc,
 	const PxgSolverSharedDesc<IterativeSolveData>* PX_RESTRICT sharedDesc)
 {
+#if PX_CUMETAL
