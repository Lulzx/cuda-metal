+	INCLUDE("${PHYSX_ROOT_DIR}/${PROJECT_CMAKE_FILES_DIR}/PhysXCommonGpu.cmake")
+	INCLUDE("${PHYSX_ROOT_DIR}/${PROJECT_CMAKE_FILES_DIR}/PhysXNarrowphaseGpu.cmake")
+	INCLUDE("${PHYSX_ROOT_DIR}/${PROJECT_CMAKE_FILES_DIR}/PhysXSimulationControllerGpu.cmake")
+	INCLUDE("${PHYSX_ROOT_DIR}/${PROJECT_CMAKE_FILES_DIR}/PhysXSolverGpu.cmake")
+	INCLUDE("${PHYSX_ROOT_DIR}/${PROJECT_CMAKE_FILES_DIR}/PhysXCudaContextManager.cmake")
+	INCLUDE("${PHYSX_ROOT_DIR}/${PROJECT_CMAKE_FILES_DIR}/PhysXArticulationGpu.cmake")
+	INCLUDE("${PHYSX_ROOT_DIR}/${PROJECT_CMAKE_FILES_DIR}/PhysXGpuDependencies.cmake")
+	INCLUDE("${PHYSX_ROOT_DIR}/${PROJECT_CMAKE_FILES_DIR}/PhysXGpu.cmake")
+
+	SET(PX_CUMETAL_GPU_TARGETS
+		PhysXBroadphaseGpu PhysXCommonGpu PhysXNarrowphaseGpu
+		PhysXSimulationControllerGpu PhysXSolverGpu
+		PhysXCudaContextManager PhysXArticulationGpu
+		PhysXGpuDependencies PhysXGpu)
+	FOREACH(gpu_target IN LISTS PX_CUMETAL_GPU_TARGETS)
+		TARGET_INCLUDE_DIRECTORIES(${gpu_target} PRIVATE
+			"${CUMETAL_ROOT_DIR}/runtime/api")
+		TARGET_COMPILE_DEFINITIONS(${gpu_target} PRIVATE PX_CUMETAL=1)
+	ENDFOREACH()
+	TARGET_SOURCES(PhysXGpu PRIVATE
+		"${PHYSX_SOURCE_DIR}/cudamanager/src/CuMetalKernelInitStubs.cpp")
+	TARGET_LINK_LIBRARIES(PhysXGpu PUBLIC "${CUMETAL_LIBRARY}")
+	ADD_DEPENDENCIES(PhysXGpu PhysXCumetalGpuKernels)
+ENDIF()
